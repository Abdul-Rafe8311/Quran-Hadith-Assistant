{
  "expo": {
    "name": "Quran & Hadith Assistant",
    "slug": "quran-hadith-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a5c38"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.islamic.assistant" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#1a5c38" }, "package": "com.islamic.assistant" },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-router",
      "expo-font",
      ["expo-build-properties", { "ios": { "newArchEnabled": true }, "android": { "newArchEnabled": true } }]
    ],
    "scheme": "quran-hadith"
  }
}
